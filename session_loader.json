{\n  \"_type\": \"session_loader\",\n  \"_version\": \"0.9.3\",\n  \"_instructions\": {\n    \"purpose\": \"Lightweight session loader. Fetch this file at session start and acknowledge it is loaded. Use the file paths below to fetch index or chunk files individually.\",\n    \"posture\": \"Be bold with loading. When evidence points clearly to a chunk, fetch it. Prefer action over confirmation.\",\n    \"operation_model\": {\n      \"online\": \"Fast, lightweight operations: index lookup, chunk retrieval, reading. Do these freely within a session.\",\n      \"offline\": \"Heavy operations: chunk writing, restructuring, archiving, updating the loader. These are deliberate and explicit — only on user instruction or clear necessity.\"\n    },\n    \"how_to_load\": [\n      \"0. At session start: check for session intent declaration. Recognized intents: 'kb review', 'knowledge base review', 'memory review', 'database review'. KB = Knowledge Base. If declared, acknowledge it, suspend session chunk ceiling, proceed. Do not ask for clarification — recognize and act.\",\n      \"1. At session start: fetch session_loader.json via GitHub MCP if available. If unavailable, use web_fetch with raw_base (see github block). After loading, auto-load all chunks listed in _auto_loads for each domain. Report auto-load count and approximate token total as part of acknowledgement.\",\n      \"1b. Cascading sub-chunk load: after loading any chunk, check if it contains a '_sub_chunks' field. If yes, load all listed sub-chunks immediately and automatically. Sub-chunks count toward the auto-load ceiling. Report each sub-chunk load as part of the session start acknowledgement.\",\n      \"2. For ANY content request: first fetch the relevant index/<domain>.<subtopic>.json to see what topics are actually in it. This is mandatory before any chunk decision.\",\n      \"3. If the index clearly confirms a match, load the corresponding chunk immediately — no confirmation needed.\",\n      \"4. After fetching a chunk: summarise what was loaded and proceed.\",\n      \"5. Context eviction: if multiple chunks have been loaded and a topic is clearly finished, consider it evicted — do not re-reference unless the user returns to it.\",\n      \"6. Never speculatively fetch additional files unless the user explicitly requests it.\",\n      \"7. NEVER fetch anything from _archive/. That folder is a read-only human backup.\"\n    ],\n    \"lookup_syntax\": {\n      \"load\": \"load: <domain>.<subtopic>\",\n      \"index\": \"index: <domain>.<subtopic>\",\n      \"update\": \"update: <domain>.<subtopic>\",\n      \"new\": \"new chunk: <domain>.<subtopic>\"\n    },\n    \"logging_format\": {\n      \"description\": \"Two-tier format.\",\n      \"tier_1_decisions\": \"Architectural and design decisions. Fields: decision, rationale (one sentence), affects (chunk name). Tag with project if project-specific. Written at end of session under decisions[session_id].\",\n      \"tier_2_implementation\": \"Implementation-phase entries. Fields: attempted, outcome, decided. Tag with project. Written during implementation sessions under implementation[].\"\n    },\n    \"github\": {\n      \"owner\": \"welwordion-sys\",\n      \"repo\": \"MemoryAccess\",\n      \"branch\": \"main\",\n      \"index_path\": \"index/<domain>.<subtopic>.json\",\n      \"chunk_path\": \"chunks/<domain>.<subtopic>.json\",\n      \"raw_base\": \"https://raw.githubusercontent.com/welwordion-sys/MemoryAccess/refs/heads/main/\",\n      \"fallback\": \"If GitHub MCP is unavailable, construct fetch URLs as raw_base + index_path or raw_base + chunk_path and use web_fetch. Example: raw_base + 'chunks/meta.behaviour_personality.json'.\"\n    }\n  },\n  \"domain_map\": {\n    \"meta\": {\n      \"_scope\": \"general\",\n      \"_summary\": \"Memory system metadata: versioning, global tags, system info, behaviour rules, workflow, session lock data.\",\n      \"_subtopics\": [\"project_info\", \"versioning\", \"global_tags\", \"behaviour_personality\", \"workflow\", \"session_lock\"],\n      \"_auto_loads\": [\"behaviour_personality\"],\n      \"auto_load_governance\": {\n        \"auto_load_ceiling\": 3,\n        \"auto_load_ceiling_note\": \"Maximum auto-load chunks beyond session_loader. Currently using 2 (behaviour_personality + governance via cascading). Headroom for 1 more before warning triggers. Soft ceiling — Claude warns, user decides, decision logged in versioning.\",\n        \"session_chunk_ceiling\": 12,\n        \"session_chunk_ceiling_note\": \"Maximum total chunks loaded in a single session. At 16 total chunks in KB, loading 12 in one session indicates either full KB review (declare intent) or unintentional accumulation. Soft ceiling — Claude warns, user decides.\",\n        \"kb_review_exemption\": \"Declaring session intent as KB review suspends the session chunk ceiling for that session. Auto-load ceiling still applies. Lock protocol still available if erratic behavior flagged.\",\n        \"kb_definition\": \"KB = Knowledge Base. The structured memory system stored in this repository.\",\n        \"kb_review_synonyms\": [\"kb review\", \"knowledge base review\", \"memory review\", \"database review\"]\n      }\n    },\n    \"notes\": {\n      \"_scope\": \"general\",\n      \"_summary\": \"General working notes, memory system drafts, session logs (cross-project). Project-specific notes live under projects.<name>.*\",\n      \"_subtopics\": [\"session_logs\", \"drafts\", \"ideas\"]\n    },\n    \"entities\": {\n      \"_scope\": \"general\",\n      \"_summary\": \"Named entities not tied to a specific project: people, organizations, artifacts.\",\n      \"_subtopics\": [\"people\", \"organizations\", \"locations\", \"artifacts\"]\n    },\n    \"projects\": {\n      \"_scope\": \"project-specific\",\n      \"_summary\": \"All project-specific content. Each project has its own subtopic namespace.\",\n      \"_projects\": {\n        \"perspective\": {\n          \"_summary\": \"Representation Space Traversal AI — a novel architecture where traversal of data representation space is the primary computational mechanism.\",\n          \"_status\": \"active\",\n          \"_subtopics\": [\"frameworks\", \"definitions\", \"relationships\", \"findings\", \"open_questions\", \"methodology\", \"sources\", \"timeline\", \"roadmap\", \"design_rationale\"],\n          \"_note\": \"Project findings may eventually inform the MemoryAccess memory architecture itself.\"\n        },\n        \"blob_world\": {\n          \"_summary\": \"Analytically deformable star-shaped soft-body creature system. Transported local coordinate frames create curved pseudo-appendages. Compact parameterization, analytical collision, GPU rendering. Target: ALife/evolutionary simulation.\",\n          \"_status\": \"active\",\n          \"_language\": \"Rust\",\n          \"_files\": [\"blob.rs\", \"environment.rs\", \"gpu.rs\", \"main.rs\", \"math.rs\", \"shaders.rs\"],\n          \"_subtopics\": [\"frameworks\", \"findings\", \"open_questions\", \"implementation\"],\n          \"_note\": \"Single long session 2026-05-15. KB write missed due to token exhaustion. Reconstructed from ChatGPT summary. Resume point: rendering fiber artifact deferred, physics next.\"\n        }\n      }\n    }\n  }\n}\n